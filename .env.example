# API base URL (the Qobuz-DL instance to use as backend)
QOBUZ_BASE_URL=https://qobuz.squid.wtf

# Browser-Cookie für API-Zugriff (nach Captcha-Lösung im Browser)
# F12 → Network → Request "/api/download-music" → Cookie-Header kopieren
# Oder leer lassen - die CLI liest ~/.qobuz-cookie und fragt beim ersten Captcha danach
QOBUZ_COOKIE=

# Optional: Datei mit Cookie-Header oder nur captcha_verified_at-Wert
QOBUZ_COOKIE_FILE=~/.qobuz-cookie

# Separates Chrome-Profil fuer automatisches Captcha/Cookie-Login via --login-cookie
QOBUZ_CHROME_PROFILE=~/.qobuz-cli/chrome-profile

# Basisordner fuer frische Chrome-Profile beim automatischen Cookie-Login
QOBUZ_CHROME_PROFILE_BASE=~/.qobuz-cli/chrome-profiles

# Cache fuer Phase-1 Qobuz-Matches, damit Neustarts nicht erneut alles suchen
QOBUZ_MATCH_CACHE=~/.qobuz-cli/match-cache.json

# Logdatei fuer Terminal-Runs via --via-terminal
QOBUZ_LOG_FILE=~/.qobuz-cli/qobuz-dl.log

# Output directory for downloaded tracks
QOBUZ_OUTPUT_DIR=./downloads

# Default quality: 27=Hi-Res, 7=FLAC 16-bit, 6=Lossless, 5=MP3 320
QOBUZ_QUALITY=7

# Ask for confirmation even with single match? (true/false)
QOBUZ_ALWAYS_CONFIRM=false

# macOS VPN note: use --via-terminal when iTerm2 is excluded from Mullvad split tunneling.

# Optional: Spotify Web API credentials for Spotify playlist URLs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
