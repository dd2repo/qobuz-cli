# API base URL (the Qobuz-DL instance to use as backend)
QOBUZ_BASE_URL=https://qobuz.squid.wtf

# Optional cookie header for Qobuz backend download requests.
# Usually created automatically with --login-cookie.
QOBUZ_COOKIE=

# Cookie file containing either the full Cookie header or the captcha_verified_at value.
QOBUZ_COOKIE_FILE=~/.qobuz-cookie

# Base directory for fresh Chrome profiles used by automatic cookie refresh.
QOBUZ_CHROME_PROFILE_BASE=~/.qobuz-cli/chrome-profiles

# Match cache used to avoid repeating search work after interrupted runs.
QOBUZ_MATCH_CACHE=~/.qobuz-cli/match-cache.json

# Log file for --via-terminal runs.
QOBUZ_LOG_FILE=~/.qobuz-cli/qobuz-dl.log

# Output directory for downloaded tracks
QOBUZ_OUTPUT_DIR=./downloads

# Default quality: 27=Hi-Res, 7=FLAC 16-bit, 6=Lossless, 5=MP3 320
QOBUZ_QUALITY=7

# Ask for confirmation even with single match? (true/false)
QOBUZ_ALWAYS_CONFIRM=false

# macOS VPN note: use --via-terminal when your current terminal is excluded from split tunneling.

# Optional: Spotify Web API credentials for Spotify playlist URLs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
